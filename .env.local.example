# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# MongoDB connection string (MongoDB Atlas or self-hosted)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/aurux?retryWrites=true&w=majority

# NextAuth — used once real auth is wired up (see src/app/api/auth/[...nextauth]/route.js)
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
